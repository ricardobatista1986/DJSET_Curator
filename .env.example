# DJ Set Curator — .env.example (ESTRUTURA — copia para .env e preenche)
# NUNCA carregues este ficheiro com valores reais para um repo público.
# O .env está no .gitignore.

# ---- Supabase (já tens) ----
SUPABASE_URL=https://kqyvpnmofrxcacjhnwsm.supabase.co
SUPABASE_KEY=

# ---- Ligações diretas à BD (worker cria a tabela jobs; opcional) ----
# Worker/local só. Supabase → Settings → Database → Connection string.
# NÃO é preciso para a app Vercel (ela usa SUPABASE_KEY). Só o worker/setup_db usam isto.
DATABASE_URL=postgresql://postgres:****@db.kqyvpnmofrxcacjhnwsm.supabase.co:5432/postgres

# ---- Spotify (já tens) ----
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---- LLM (provedor: groq | openrouter | gemini) ----
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ---- Login da app (tu + quem souberes a senha) ----
APP_USER=ricardo.rocha.nb@gmail.com
APP_PASSWORD=
